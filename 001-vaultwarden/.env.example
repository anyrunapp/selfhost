# 复制为 .env 后修改。PORT_* / APP_* 由 bin/ports.sh --write 自动生成,不要手写。
# 注意:.env 里的值会被 compose 做 ${} 插值,密码中的 $ 需写成 $$

# ---- 镜像版本(建议锁定具体版本,不要用 latest) ----
# VAULTWARDEN_TAG=1.34.3-alpine
VAULTWARDEN_TAG=latest
POSTGRES_TAG=16-alpine

# ---- 基础 ----
TZ=Asia/Shanghai
DOMAIN=https://vault.example.com
LOG_LEVEL=warn
WEB_VAULT_ENABLED=true
REQUIRE_DEVICE_EMAIL=true

# ---- 注册策略 ----
SIGNUPS_ALLOWED=false
INVITATIONS_ALLOWED=true
# SIGNUPS_DOMAINS_WHITELIST=example.com

# ---- PostgreSQL ----
POSTGRES_DB=vaultwarden
POSTGRES_USER=vaultwarden
# 只用字母数字,避免 URL 编码问题:openssl rand -hex 24
# 记得修改密码
POSTGRES_PASSWORD=CHANGE_ME

# ---- SMTP(可留空) ----
SMTP_FROM_NAME=Vaultwarden
SMTP_HOST=
SMTP_FROM=
SMTP_PORT=587
SMTP_SECURITY=starttls
SMTP_USERNAME=
SMTP_PASSWORD=

# ---- 推送通知(移动客户端，可选) ----
# https://bitwarden.com/host/ 申请
PUSH_ENABLED=false
PUSH_INSTALLATION_ID=
PUSH_INSTALLATION_KEY=
# EU 区域(bitwarden.eu),还需要额外指定中继地址
# PUSH_RELAY_URI=https://api.bitwarden.eu
# PUSH_IDENTITY_URI=https://identity.bitwarden.eu

# ---- YubiKey OTP 二次验证 ----
YUBICO_CLIENT_ID=
YUBICO_SECRET_KEY=

# ----- 启用 Duo ---------------
# DUO_IKEY=
# DUO_SKEY=
# DUO_HOST=
